{
  "version": 8,
  "name": "Basic",
  "metadata": {
    "mapbox:autocomposite": false,
    "mapbox:type": "template",
    "maputnik:renderer": "mbgljs",
    "openmaptiles:version": "3.x",
    "openmaptiles:mapbox:owner": "openmaptiles",
    "openmaptiles:mapbox:source:url": "mapbox://openmaptiles.4qljc88t"
  },
  "terrain": {"exaggeration": 0},
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://api.maptiler.com/tiles/v3-openmaptiles/tiles.json?key=HMcoWV4vYRMsVcY9TTFb"
    },
    "textures1": {
      "type": "raster",
      "tiles": [
        "https://t0.tianditu.gov.cn/DataServer?T=img_w&x={x}&y={y}&l={z}&tk=1b4f54a9ee5f95de4fcd0eaf4df87e5f"
      ],
      "minzoom": 7,
      "maxzoom": 20,
      "scheme": "xyz",
      "tileSize": 256
    },
    "resource": {
      "type": "vector",
      "url": "pmtiles://http://139.224.215.240:9876/directlink/1/nature_resource_4_17.pmtiles"
    },
    "quhua": {
      "type": "vector",
      "url": "pmtiles://http://139.224.215.240:9876/directlink/1/guangxi_quhua.pmtiles"
    }
  },
  "sprite": "https://baitianyi.github.io/pmtiles-netlify-host/sprite/sprite",
  "glyphs": "https://api.maptiler.com/fonts/{fontstack}/{range}.pbf?key=HMcoWV4vYRMsVcY9TTFb",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "maxzoom": 20,
      "paint": {"background-color": "hsl(47, 26%, 88%)"}
    },
    {
      "id": "ziranziyuan-textures",
      "type": "raster",
      "source": "textures1",
      "layout": {"visibility": "visible"},
      "paint": {"raster-opacity": 1}
    },
    {
      "id": "caodi1",
      "type": "fill",
      "source": "resource",
      "source-layer": "6草地",
      "maxzoom": 17,
      "layout": {"visibility": "visible"},
      "paint": {"fill-color": "rgba(241, 215, 112, 1)"}
    },
    {
      "id": "guangxi-quhua",
      "type": "line",
      "source": "quhua",
      "source-layer": "行政区划界限",
      "paint": {"line-color": "rgba(246, 243, 243, 1)", "line-width": 2}
    },
    {
      "id": "waterway-tunnel",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": [
        "all",
        ["==", "$type", "LineString"],
        ["==", "brunnel", "tunnel"]
      ],
      "layout": {"visibility": "visible"},
      "paint": {
        "line-color": "hsl(205, 56%, 73%)",
        "line-dasharray": [3, 3],
        "line-gap-width": {"stops": [[12, 0], [20, 6]]},
        "line-opacity": 1,
        "line-width": {"base": 1.4, "stops": [[8, 1], [20, 2]]}
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": [
        "all",
        ["==", "$type", "LineString"],
        ["!in", "brunnel", "tunnel", "bridge"],
        ["!=", "intermittent", 1]
      ],
      "layout": {"visibility": "visible"},
      "paint": {
        "line-color": "hsl(205, 56%, 73%)",
        "line-opacity": 1,
        "line-width": {"base": 1.4, "stops": [[8, 1], [20, 8]]}
      }
    },
    {
      "id": "waterway_intermittent",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "waterway",
      "filter": [
        "all",
        ["==", "$type", "LineString"],
        ["!in", "brunnel", "tunnel", "bridge"],
        ["==", "intermittent", 1]
      ],
      "layout": {"visibility": "visible"},
      "paint": {
        "line-color": "hsl(205, 56%, 73%)",
        "line-dasharray": [2, 1],
        "line-opacity": 1,
        "line-width": {"base": 1.4, "stops": [[8, 1], [20, 8]]}
      }
    },
    {
      "id": "icon-nanning",
      "type": "circle",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": ["all", ["==", "name", "南宁市"]],
      "layout": {"visibility": "visible"},
      "paint": {
        "circle-color": "rgba(230, 94, 11, 1)",
        "circle-radius": 6,
        "circle-stroke-width": 1.3,
        "circle-stroke-color": "rgba(252, 243, 243, 1)"
      }
    },
    {
      "id": "circle-layer-icon",
      "type": "circle",
      "source": "openmaptiles",
      "source-layer": "place",
      "filter": [
        "all",
        ["==", "$type", "Point"],
        ["==", "class", "city"],
        [
          "in",
          "name",
          "百色市",
          "崇左市",
          "防城港市",
          "钦州市",
          "北海市",
          "玉林市",
          "北海市",
          "贵港市",
          "梧州市",
          "贺州市",
          "桂林市",
          "来宾市",
          "柳州市",
          "河池市"
        ]
      ],
      "layout": {"visibility": "visible"},
      "paint": {
        "circle-color": "rgba(243, 166, 4, 1)",
        "circle-stroke-color": "rgba(237, 236, 236, 1)",
        "circle-stroke-width": 1,
        "circle-radius": 5
      }
    },
    {
      "id": "place_label_city-fangchenggang",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 16,
      "filter": [
        "all",
        ["==", "$type", "Point"],
        ["==", "class", "city"],
        ["==", "name", "防城港市"]
      ],
      "layout": {
        "text-field": "{name:nonlatin}",
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 10,
        "text-size": {"stops": [[3, 12], [8, 16]]},
        "icon-size": 1,
        "text-offset": [2.5, 0],
        "icon-offset": [2.5, 0]
      },
      "paint": {
        "text-color": "rgba(208, 100, 9, 1)",
        "text-halo-blur": 0,
        "text-halo-color": "hsla(0, 0%, 100%, 0.75)",
        "text-halo-width": 2,
        "text-opacity": 1
      }
    },
    {
      "id": "place_label_city",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "minzoom": 4,
      "maxzoom": 16,
      "filter": [
        "all",
        ["==", "$type", "Point"],
        ["==", "class", "city"],
        [
          "in",
          "name",
          "百色市",
          "崇左市",
          "钦州市",
          "北海市",
          "玉林市",
          "北海市",
          "贵港市",
          "梧州市",
          "贺州市",
          "桂林市",
          "来宾市",
          "柳州市",
          "河池市"
        ]
      ],
      "layout": {
        "text-field": "{name:nonlatin}",
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 10,
        "text-size": {"stops": [[3, 15], [8, 16]]},
        "icon-size": 1,
        "text-offset": [2, 0],
        "text-allow-overlap": true,
        "text-padding": 0.5
      },
      "paint": {
        "text-color": "rgba(208, 100, 9, 1)",
        "text-halo-blur": 0,
        "text-halo-color": "hsla(0, 0%, 100%, 0.75)",
        "text-halo-width": 2,
        "text-opacity": 1
      }
    },
    {
      "id": "place_label_city-nanning",
      "type": "symbol",
      "source": "openmaptiles",
      "source-layer": "place",
      "maxzoom": 16,
      "filter": [
        "all",
        ["==", "$type", "Point"],
        ["==", "class", "city"],
        ["==", "name", "南宁市"]
      ],
      "layout": {
        "text-field": "{name:nonlatin}",
        "text-font": ["Noto Sans Regular"],
        "text-max-width": 10,
        "text-size": {"stops": [[6, 19], [8, 16]]},
        "icon-allow-overlap": false,
        "text-offset": [2, 0]
      },
      "paint": {
        "text-color": "rgba(202, 19, 3, 1)",
        "text-halo-blur": 0,
        "text-halo-color": "hsla(0, 0%, 100%, 0.75)",
        "text-halo-width": 3
      }
    }
  ],
  "id": "basic"
}